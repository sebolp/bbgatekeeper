<!DOCTYPE html>
<html lang="en">
<head>
	<meta charset="UTF-8">
	<meta name="viewport" content="width=device-width, initial-scale=1.0">
	<title>{{BB_LOGGER_LANG_SECURITY_CHECK}}</title>
	<style>
		body {
			font-family: sans-serif;
			text-align: center;
			padding: 2rem;
			line-height: 1.6;
			background-color: #f9f9f9;
			color: #333;
		}
		.container {
			max-width: 600px;
			margin: 0 auto;
			background: #fff;
			padding: 2rem;
			border-radius: 8px;
			box-shadow: 0 4px 10px rgba(0,0,0,0.1);
		}
		.spinner {
			margin: 20px auto;
			width: 40px;
			height: 40px;
			border: 4px solid rgba(0, 0, 0, 0.1);
			border-left-color: #007bff;
			border-radius: 50%;
			animation: spin 1s linear infinite;
		}
		@keyframes spin {
			0% { transform: rotate(0deg); }
			100% { transform: rotate(360deg); }
		}
	</style>
</head>
<body>
	<div class="container">
		<h2>{{BB_LOGGER_LANG_SECURITY_CHECK}}</h2>
		<p>{{BB_LOGGER_LANG_SECURITY_CHECK_EXPLAIN}}</p>
		
		<div class="spinner"></div>

		<noscript>
			<p style="color: red; font-weight: bold;">
				{{BB_LOGGER_LANG_SECURITY_CHECK_COOKIE}}
			</p>
		</noscript>
	</div>

	<script>
		// Wait 2 seconds to ensure the browser processes the script and to slow down rapid requests
		setTimeout(function()
		{
			// Set a clearance cookie valid for 1 week
			var d = new Date();
			d.setTime(d.getTime() + (7 * 24 * 60 * 60 * 1000));
			var expires = "expires=" + d.toUTCString();
			
			// Cookie path=/ ensures it works for the whole forum
			document.cookie = "sebo-bbgatekeeper_clearance=granted; " + expires + "; path=/; SameSite=Lax";
			
			// Reload the original requested URL
			window.location.reload(true);
		}, 2000);
	</script>
</body>
</html>